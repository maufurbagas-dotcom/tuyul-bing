{
  "version": 2,
  "routes": [
    { "src": "^/$",           "dest": "/login.html"     },
    { "src": "^/login$",      "dest": "/login.html"     },
    { "src": "^/dashboard$",  "dest": "/dashboard.html" },
    { "src": "/(.*\\.html)$", "dest": "/$1"             },
    { "src": "/(.*)",         "dest": "/login.html"     }
  ]
}
